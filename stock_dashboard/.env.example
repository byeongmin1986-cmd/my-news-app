# ─────────────────────────────────────────────────────────────
# 주식 대시보드 환경 변수 설정 파일
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채워주세요:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── AI 분석 API (하나만 있어도 됩니다) ───────────────────────
# Anthropic Claude (권장, https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI GPT (대안, https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# ── 뉴스 API (선택 사항) ────────────────────────────────────
# Finnhub: 미국 주식 뉴스 (무료 플랜 가능, https://finnhub.io)
# 없으면 Google News RSS로 자동 대체됩니다.
FINNHUB_API_KEY=your_finnhub_api_key_here

# Alpha Vantage: 추가 뉴스 소스 (현재 사용 안 함, 향후 확장용)
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
