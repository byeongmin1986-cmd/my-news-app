{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      ".github/**",
      "README.md"
    ],
    "rewrites": [
      {
        "source": "/tamagotchi",
        "destination": "/tamagotchi.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
